@model WatchReadLibrary.Models.LibraryItem

@{
    ViewData["Title"] = Model.Title;
}

<section class="cinematic-details">
    <div class="details-backdrop" style="background-image: url('@Model.CoverPath');"></div>

    <div class="cinematic-content">
        <div class="cinematic-poster">
            @if (!string.IsNullOrWhiteSpace(Model.CoverPath))
            {
                <img src="@Model.CoverPath"
                     alt="@Model.Title"
                     class="details-poster-clickable"
                     onclick="openPosterPreview('@Model.CoverPath', '@Model.Title')" />
            }
            else
            {
                <div class="cover-placeholder">No cover</div>
            }
        </div>

        <div class="cinematic-info">
            <p class="section-label">@Model.Category</p>

            <h1>
                @Model.Title
                @if (Model.Year > 0)
                {
                    <span>(@Model.Year)</span>
                }
            </h1>

            <div class="details-meta">
                <div class="meta-card">
                    <span>Рейтинг</span>
                    <strong>@Model.Rating / 10</strong>
                </div>

                <div class="meta-card">
                    <span>Статус</span>
                    <strong>@Model.Status</strong>
                </div>

                <div class="meta-card">
                    <span>Улюблене</span>
                    <strong>@(Model.IsFavorite ? "Так" : "Ні")</strong>
                </div>
            </div>

            <div class="details-text-block">
                <h2>Опис</h2>
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "Опис ще не додано." : Model.Description)</p>
            </div>

            <div class="details-text-block">
                <h2>Відгук</h2>
                <p>@(string.IsNullOrWhiteSpace(Model.Review) ? "Відгук ще не додано." : Model.Review)</p>
            </div>

            <div class="details-buttons">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="details-btn primary">Редагувати</a>
                <a asp-action="Index" class="details-btn secondary">Назад до бібліотеки</a>
            </div>
        </div>
    </div>
</section>