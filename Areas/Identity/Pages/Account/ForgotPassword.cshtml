@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Відновлення пароля";
}

<section class="auth-page">
    <div class="auth-card">
        <p class="section-label">PASSWORD RESET</p>

        <h1>Забули пароль?</h1>

        <p class="auth-text">
            Введіть email, який використовувався під час реєстрації.
            Ми надішлемо посилання для відновлення пароля.
        </p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control"
                       autocomplete="email"
                       placeholder="name@example.com" />

                <label asp-for="Input.Email"></label>

                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="details-btn primary auth-submit">
                Надіслати посилання
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}