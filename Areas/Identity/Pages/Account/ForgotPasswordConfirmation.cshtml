@page
@model ForgotPasswordConfirmation

@{
    ViewData["Title"] = "Лист надіслано";
}

<section class="auth-page">
    <div class="auth-card">
        <p class="section-label">CHECK YOUR EMAIL</p>

        <h1>Перевірте пошту</h1>

        <p class="auth-text">
            Якщо акаунт з таким email існує, ми надіслали посилання для відновлення пароля.
            Відкрийте лист і перейдіть за посиланням, щоб створити новий пароль.
        </p>

        <a asp-page="./Login" class="details-btn primary auth-submit">
            Повернутися до входу
        </a>
    </div>
</section>